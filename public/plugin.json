{
  "name": "FRP 多节点客户端",
  "version": "1.0.0",
  "description": "管理多个 FRP 客户端连接，配置服务端和隧道，生成 frpc.toml 并启动隧道",
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "my-logo.png",
  "development": {
    "main": "http://localhost:5173"
  },
  "features": [
    {
      "code": "tunnel",
      "explain": "管理 FRP 隧道：新增、编辑、启停隧道连接",
      "cmds": [
        "隧道设置",
        "隧道",
        "tunnel"
      ]
    },
    {
      "code": "server",
      "explain": "管理 FRP 服务端：配置服务端地址、端口和认证信息",
      "cmds": [
        "服务端设置",
        "服务端",
        "server"
      ]
    },
    {
      "code": "environment",
      "explain": "查看和配置运行环境：frpc 二进制文件路径、版本、替换运行文件",
      "cmds": [
        "设置",
        "环境设置",
        "settings"
      ]
    }
  ]
}
